{
    "terminal.integrated.defaultProfile.windows": "Ubuntu (WSL)",
    "explorer.excludeGitIgnore": false,
    "files.exclude": {
        ".git": true,
        ".gitignore": true,
        ".pytest_cache": true,
        ".venv": true,
        ".vscode": true,
        "AGENTS.md": true,
        "LICENSE": true,
        "agents": true,
        "fonts": true,
        "pytest.ini": true,
        "setup.sh": false,
        "setup-wsl-git.sh": true,
        ".gitattributes": true,
        ".editorconfig": true,
        "thesis/config.sty": true,
        "thesis/findSegment.py": true,
        "src": true,
        "temp": true,
        "tests": true,
        "**/.gitignore": true,
        "thesis/**/*.aux": true,
        "thesis/**/*.tmp": true,
        "thesis/**/*.acn": true,
        "thesis/**/*.acr": true,
        "thesis/**/*.alg": true,
        "thesis/**/*.bbl": true,
        "thesis/**/*.bcf": true,
        "thesis/**/*.blg": true,
        "thesis/**/*.cpt": true,
        "thesis/**/*.data.minted": true,
        "thesis/**/*.dvi": true,
        "thesis/**/*.fdb_latexmk": true,
        "thesis/**/*.fls": true,
        "thesis/**/*.glg": true,
        "thesis/**/*.glo": true,
        "thesis/**/*.gls": true,
        "thesis/**/*.glsdefs": true,
        "thesis/**/*.ist": true,
        "thesis/**/*.log": true,
        "thesis/**/*.out": true,
        "thesis/**/*.pagecount": true,
        "thesis/**/*.pyg": true,
        "thesis/**/*.run.xml": true,
        "thesis/**/*.synctex*": true,
        "thesis/**/*.toc": true,
        "thesis/**/*.upa": true,
        "thesis/**/*.xdv": true,
        "thesis/**/*-insert-code-*.tmp": true,
        "thesis/**/*-SAVE-ERROR": true,
        "thesis/**/_minted*": true,
        "thesis/**/errors.txt": true,
        "thesis/**/generated-code-segments": true,
        "thesis/**/output": true,
        ".render-venv": true,
        "*/__pycache__": true,
        "**/*requirements.txt": true,
    },
    "search.exclude": {
        ".pytest_cache": true,
        ".venv": true,
        "agents": true,
        "fonts": true,
        "src": true,
        "temp": true,
        "tests": true
    }
}
