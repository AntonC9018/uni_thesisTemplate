% Appendix reference validation
% References are recorded in the aux file so the final latexmk pass can
% render warnings exactly where the uncovered appendix labels are defined.
\makeatletter
\newif\ifconfig@inappendix
\config@inappendixfalse
\newif\ifconfig@firstAppendixSection
\newif\ifconfig@referenceValidationDataReady
\config@referenceValidationDataReadyfalse
\let\config@currentAppendixSectionLabel\@empty
\let\config@currentLabelType\@empty
\def\config@sectionLabelType{section}
\def\config@appendixLabelType{appendix}
\def\config@subappendixLabelType{subappendix}
\newif\ifconfig@currentLabelIsAppendixSection

\def\config@extractCrefType[#1]#2\@nil{%
  \def\config@currentLabelType{#1}%
}

\newcommand{\config@setCurrentLabelType}{%
  \let\config@currentLabelType\@empty
  \ifx\cref@currentlabel\@empty
  \else
    \expandafter\config@extractCrefType\cref@currentlabel\@nil
  \fi
}

\newcommand{\config@clearCurrentAppendixSection}{%
  \global\let\config@currentAppendixSectionLabel\@empty
}

\newcommand{\config@setCurrentAppendixSectionLabel}[1]{%
  \config@setCurrentLabelType
  \config@currentLabelIsAppendixSectionfalse
  \ifx\config@currentLabelType\config@sectionLabelType
    \config@currentLabelIsAppendixSectiontrue
  \fi
  \ifx\config@currentLabelType\config@appendixLabelType
    \config@currentLabelIsAppendixSectiontrue
  \fi
  \ifx\config@currentLabelType\config@subappendixLabelType
    \config@currentLabelIsAppendixSectiontrue
  \fi
  \ifconfig@currentLabelIsAppendixSection
    \gdef\config@currentAppendixSectionLabel{#1}%
  \fi
}

\newcommand{\config@mainReferencedLabel}[1]{%
  \global\@namedef{config@main@referenced@#1}{1}%
}

\newcommand{\config@appendixReferencedLabel}[1]{%
  \global\@namedef{config@appendix@referenced@#1}{1}%
}

\newcommand{\config@markReferenceValidationDataReady}{%
  \global\config@referenceValidationDataReadytrue
}

\AtBeginDocument{%
  \protected@write\@auxout{}{%
    \string\config@markReferenceValidationDataReady
  }%
}

\newcommand{\config@recordReferencedLabel}[1]{%
  \ifconfig@inappendix
    \protected@write\@auxout{}{%
      \string\config@appendixReferencedLabel{#1}%
    }%
  \else
    \protected@write\@auxout{}{%
      \string\config@mainReferencedLabel{#1}%
    }%
  \fi
}

\newcommand{\config@recordReferencedAppendixLabel}[1]{%
  \config@recordReferencedLabel{#1}%
}

\newcommand{\config@recordReferencedAppendixLabels}[1]{%
  \begingroup
    \@for\config@referencedLabel:=#1\do{%
      \ifx\config@referencedLabel\@empty
      \else
        \config@recordReferencedLabel{\config@referencedLabel}%
      \fi
    }%
  \endgroup
}

\newcommand{\config@ifMainLabelReferenced}[3]{%
  \ifcsname config@main@referenced@#1\endcsname
    #2%
  \else
    #3%
  \fi
}

\newcommand{\config@ifLabelReferenced}[3]{%
  \config@ifMainLabelReferenced{#1}{#2}{#3}%
}

\newcommand{\config@appendixReferenceWarning}[1]{%
  \PackageWarning{config}{Appendix label '\detokenize{#1}' is not referenced}%
  \par\noindent\textbf{\textcolor{red}{%
    \appendixReferenceWarning{\texttt{\detokenize{#1}}}%
  }}\par
}

\newcommand{\config@floatReferenceWarning}[1]{%
  \PackageWarning{config}{Float label '\detokenize{#1}' is not referenced}%
  \par\noindent\textbf{\textcolor{red}{%
    \floatReferenceWarning{\texttt{\detokenize{#1}}}%
  }}\par
}

\newcommand{\config@warnIfAppendixLabelUncovered}[1]{%
  \def\config@checkedAppendixLabel{#1}%
  \ifx\config@currentAppendixSectionLabel\@empty
    \config@appendixReferenceWarning{#1}%
  \else
    \ifx\config@checkedAppendixLabel\config@currentAppendixSectionLabel
      \config@appendixReferenceWarning{#1}%
    \else
      \config@ifLabelReferenced{\config@currentAppendixSectionLabel}
        {}
        {\config@appendixReferenceWarning{#1}}%
    \fi
  \fi
}

\newcommand{\config@checkAppendixLabelReference}[1]{%
  \ifconfig@inappendix
    \config@setCurrentAppendixSectionLabel{#1}%
    \ifconfig@referenceValidationDataReady
      \config@ifLabelReferenced{#1}
        {}
        {\config@warnIfAppendixLabelUncovered{#1}}%
    \fi
  \fi
}

\newcommand{\config@checkFloatLabelReference}[1]{%
  \ifconfig@inappendix
  \else
    \ifconfig@referenceValidationDataReady
      \config@ifLabelReferenced{#1}
        {}
        {\config@floatReferenceWarning{#1}}%
    \fi
  \fi
}

\let\config@original@label\label
\renewcommand{\label}[1]{%
  \config@original@label{#1}%
  \config@checkAppendixLabelReference{#1}%
}

