% change counter
\RequirePackage{chngcntr}

\makeatletter
\def\appendixChapter{%
  % Appendices don't have the dot when referencing.
  % If you have multiple chapters in appendices, you'll have to reconfigure this.
  \renewcommand{\thesection}{\arabic{section}}%
  \titleformat{\section}[block]{\normalfont\normalsize\bfseries\filcenter}{\anexaLabel{} \thesection.~}{0pt}{}%
  \appendix
  %
  % Every section on new page
  % \newcommand{\sectionbreak}{\clearpage}
  %
  % Since we've got just a single chapter in the appedices,
  % but which is also the name of the Appendix chapter, it should be omitted.
  % Makes little sense, but ok I guess.
  \setcounter{chapter}{1}%
  \enableAppendixReferenceValidation

  \counterwithin{figure}{section}
  \counterwithin{table}{section}
  \counterwithin{equation}{section}
  % Redefine the numbering for images and tables in appendices.
  \renewcommand{\thefigure}{\appendixReferenceLetter{}\arabic{section}.\arabic{figure}}
  \renewcommand{\thetable}{\appendixReferenceLetter{}\arabic{section}.\arabic{table}}
  \renewcommand{\theequation}{\appendixReferenceLetter{}\arabic{section}.\arabic{equation}}

  %
  % Counter, again, looks at sections rather than subsections.
  \let\config@oldsection\section
  \RenewDocumentCommand{\section}{s o m}{%
    \ifconfig@firstAppendixSection
      \global\config@firstAppendixSectionfalse
    \else
      \clearpage
    \fi
    \config@clearCurrentAppendixSection
    \IfBooleanTF{##1}
      {%
        \config@oldsection*{##3}%
      }%
      {%
        \stepcounter{num_appendices}%
        \IfNoValueTF{##2}
          {\def\config@appendixTocEntry{##3}}%
          {\def\config@appendixTocEntry{##2}}%
        \let\config@original@addcontentsline\addcontentsline
        \renewcommand{\addcontentsline}[3]{%
          \ifstrequal{####1}{toc}{%
            \ifstrequal{####2}{section}{%
              \config@original@addcontentsline{####1}{####2}{%
                \protect\numberline{\anexaLabel{} \thesection}\config@appendixTocEntry
              }%
            }{%
              \config@original@addcontentsline{####1}{####2}{####3}%
            }%
          }{%
            \config@original@addcontentsline{####1}{####2}{####3}%
          }%
        }%
        \IfNoValueTF{##2}
          {\config@oldsection{##3}}%
          {\config@oldsection[##2]{##3}}%
        \let\addcontentsline\config@original@addcontentsline
      }%
  }%

  \unnumberedChapter{\appendixChapterName}
  \global\config@firstAppendixSectiontrue
  \addtocontents{toc}{\protect\configAppendixTocSectionEntries}
}
\makeatother

