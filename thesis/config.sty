% Count bibliography entries.
% https://tex.stackexchange.com/a/536720
\newcommand*{\listcounted}{}
\makeatletter
\AtDataInput{%
  \xifinlist{\abx@field@entrykey}\listcounted
    {}
    {\stepcounter{num_bib_entries}%
     \listxadd\listcounted{\abx@field@entrykey}}%
}
\makeatother

