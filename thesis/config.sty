% Internal helper: handles the starred/label logic shared by \insertImage and \insertTable.
% #1 - Boolean (star flag)
% #2 - Optional label
% #3 - Fallback label (used when #2 is absent in unstarred form)
% #4 - Command name (for error messages)
\makeatletter
\NewDocumentCommand{\insertFloatLabelHelper}{momm}{%
  \IfBooleanTF{#1}
    {%
      \ifconfig@inappendix
        \IfNoValueF{#2}{%
          \PackageError{#4}
            {Label '#2' given with starred \csname #4\endcsname. The starred form suppresses the caption number and cannot produce
             a \string\label. Remove the optional label argument or use the
             unstarred form.}
            {}%
        }%
      \else
        \PackageError{#4}
          {Starred \csname #4\endcsname is only allowed in appendices. Main-document floats must be numbered and referenced.}
          {Use the unstarred form with a label, or move this float after \string\appendixChapter.}%
      \fi
    }%
    {%
      \IfNoValueTF{#2}
        {%
          \ifx\relax#3\relax
            \PackageError{#4}
              {No label given for \csname #4\endcsname. The unstarred form requires a label argument so the float can be
               cross-referenced. Add [yourlabel] or use the starred form to
               suppress numbering entirely.}
              {}%
          \else
            \label{#3}%
            \config@checkFloatLabelReference{#3}%
          \fi
        }%
        {%
          \label{#2}%
          \config@checkFloatLabelReference{#2}%
        }%
    }%
}
\makeatother

