\newcommand{\config@setObjectReferenceType}[1]{%
  \def\config@objectReferenceType{default}%
  \expandafter\config@extractFirstReferenceLabel#1,\@nil
  \expandafter\ifx\csname r@\config@firstReferenceLabel @cref\endcsname\relax
  \else
    \cref@gettype{\config@firstReferenceLabel}{\config@objectReferenceType}%
  \fi
}

\newcommand{\config@printObjectReferenceName}[2]{%
  \ifcsname config@objectName@#1@#2@\config@objectReferenceType\endcsname
    \csname config@objectName@#1@#2@\config@objectReferenceType\endcsname
  \else
    \csname config@objectName@#1@#2@default\endcsname
  \fi
}

\newcommand{\config@linkedObjectReference}[4]{%
  \hyperref[#1]{%
    \config@printObjectReferenceName{#2}{#3}%
    ~\config@original@labelcref*{#4}%
  }%
}

\expandafter\newcommand\csname config@objectReferenceConjunction@ru\endcsname{и}
\expandafter\newcommand\csname config@objectReferenceConjunction@ro\endcsname{și}
\newcommand{\config@objectReferenceConjunction}[1]{%
  \ifcsname config@objectReferenceConjunction@#1\endcsname
    \csname config@objectReferenceConjunction@#1\endcsname
  \else
    \csname config@objectReferenceConjunction@ru\endcsname
  \fi
}

\newcount\config@objectReferenceLabelCount
\newcount\config@objectReferenceLabelIndex

\newcommand{\config@pluralObjectReference}[3]{%
  \begingroup
    \def\config@objectReferenceLanguage{#1}%
    \def\config@objectReferenceForm{#2}%
    \def\config@objectReferenceLabels{#3}%
    \config@objectReferenceLabelCount=1\relax
    \config@pluralObjectReferenceCollect
}

\newcommand{\config@pluralObjectReferenceCollect}{%
  \@ifnextchar\bgroup
    {\config@pluralObjectReferenceCollectOne}
    {\config@pluralObjectReferenceFinish}%
}

\newcommand{\config@pluralObjectReferenceCollectOne}[1]{%
  \expandafter\def\expandafter\config@objectReferenceLabels\expandafter{\config@objectReferenceLabels,#1}%
  \advance\config@objectReferenceLabelCount by 1\relax
  \config@pluralObjectReferenceCollect
}

\newcommand{\config@pluralObjectReferenceSeparator}{%
  \ifnum\config@objectReferenceLabelIndex=\config@objectReferenceLabelCount
    ~\config@objectReferenceConjunction{\config@objectReferenceLanguage}~%
  \else
    ,~%
  \fi
}

\newcommand{\config@printPluralObjectReferenceList}{%
  \config@objectReferenceLabelIndex=0\relax
  \@for\config@currentReferenceLabel:=\config@objectReferenceLabels\do{%
    \advance\config@objectReferenceLabelIndex by 1\relax
    \ifnum\config@objectReferenceLabelIndex=1
      \hyperref[\config@currentReferenceLabel]{%
        \config@printObjectReferenceName{\config@objectReferenceLanguage}{\config@objectReferenceForm}%
        ~\config@original@labelcref*{\config@currentReferenceLabel}%
      }%
    \else
      \config@pluralObjectReferenceSeparator
      \hyperref[\config@currentReferenceLabel]{\config@original@labelcref*{\config@currentReferenceLabel}}%
    \fi
  }%
}

\newcommand{\config@pluralObjectReferenceFinish}{%
    \config@recordReferencedAppendixLabels{\config@objectReferenceLabels}%
    \config@setObjectReferenceType{\config@objectReferenceLabels}%
    \config@printPluralObjectReferenceList
  \endgroup
}

\newcommand{\config@objectReference}[3]{%
  \config@recordReferencedAppendixLabels{#3}%
  \begingroup
    \config@setObjectReferenceType{#3}%
    \expandafter\config@linkedObjectReference\expandafter{\config@firstReferenceLabel}{#1}{#2}{#3}%
  \endgroup
}

