% if 1 author: CURMANSCHII, A.
% if 2 authors: CURMANSCHII, A., another author
% if >2 authors: CURMANSCHII, A. et al.
\def\authorNameHelper{
  \MakeUppercase{\namepartfamily}%
  \ifdefvoid{\namepartgiven}{}{\space\MakeUppercase{\namepartgiveni}}%
}%
\def\authorNamesHelper{%
  \ifnum\value{listtotal}=1%
    \authorNameHelper%
  \else%
    \ifnum\value{listtotal}=2%
      \authorNameHelper%
      \ifnum\value{listcount}=1%
        \addcomma\space%
      \fi%
    \else%
      % Three or more authors
      \ifnum\value{listcount}=1%
        \authorNameHelper\addspace et al.%
      \fi%
    \fi%
  \fi%
}%

\DeclareNameFormat{author}{\mkbibbold{\authorNamesHelper}}
\DeclareNameFormat{editor}{\mkbibbold{\authorNamesHelper}}

\def\helperFormat{%
  \usebibmacro{begentry}%
  % Authors/Editors/Contributors
  \usebibmacro{author/editor}%
  \setunit{\addperiod\space}%
  \printnames{translator}%
  \setunit{\addperiod\space}%
  \printnames{annotator}%
  \setunit{\addperiod\space}%
  \printnames{commentator}%
  \setunit{\addperiod\space}%
  % Title and subtitle
  \printfield{title}%
  \setunit{\addperiod\space}%
  \printfield{subtitle}%
  \setunit{\addperiod\space}%
  \printfield{titleaddon}%
  \setunit{\addperiod\space}%
  % Main title (for multi-volume works)
  \printfield{maintitle}%
  \setunit{\addperiod\space}%
  \printfield{mainsubtitle}%
  \setunit{\addperiod\space}%
  % Book title (for parts of books/proceedings)
  \printfield{booktitle}%
  \setunit{\addperiod\space}%
  \printfield{booksubtitle}%
  \setunit{\addperiod\space}%
  % Journal title (for articles)
  \printfield{journaltitle}%
  \setunit{\addperiod\space}%
  \printfield{issuetitle}%
  \setunit{\addperiod\space}%
  % Event information (for conferences)
  \printfield{eventtitle}%
  \setunit{\addperiod\space}%
  \printfield{eventdate}%
  \setunit{\addperiod\space}%
  \printfield{venue}%
  \setunit{\addperiod\space}%
  % Edition
  \printfield{edition}%
  \setunit{\addperiod\space}%
  % Volume/Part/Chapter information
  \printfield{volume}%
  \setunit{\addperiod\space}%
  \printfield{volumes}%
  \setunit{\addperiod\space}%
  \printfield{part}%
  \setunit{\addperiod\space}%
  \printfield{issue}%
  \setunit{\addperiod\space}%
  \printfield{chapter}%
  \setunit{\addperiod\space}%
  \printfield{type}%
  \setunit{\addperiod\space}%
  % Series
  \printfield{series}%
  \setunit{\addperiod\space}%
  \printfield{number}%
  \setunit{\addperiod\space}%
  % Publication info
  \printlist{location}%
  \setunit{\addcolon\space}%
  \printlist{publisher}%
  \printlist{institution}%
  \setunit{\addcomma\space}%
  \printfield{year}%
  \setunit{\addperiod\space}%
  \printfield{month}%
  \setunit{\addperiod\space}%
  \printfield{pubstate}%
  \setunit{\addperiod\space}%
  % Physical description
  \printfield{pages}%
  \setunit{\addperiod\space}%
  \printfield{pagetotal}%
  \setunit{\addperiod\space}%
  \printfield{eid}%
  \setunit{\addperiod\space}%
  % Version/Language
  \printfield{version}%
  \setunit{\addperiod\space}%
  \printfield{language}%
  \setunit{\addperiod\space}%
  % Original publication info (for translations)
  \printfield{origlanguage}%
  \setunit{\addperiod\space}%
  \printfield{origtitle}%
  \setunit{\addperiod\space}%
  % Identifiers
  \printfield{isbn}%
  \setunit{\addperiod\space}%
  \printfield{issn}%
  \setunit{\addperiod\space}%
  \printfield{isrn}%
  \setunit{\addperiod\space}%
  \printfield{doi}%
  \setunit{\addperiod\space}%
  \printfield{eprint}%
  \setunit{\addperiod\space}%
  \printfield{url}%
  \setunit{\addperiod\space}%
  \usebibmacro{urldate}%
  \setunit{\addperiod\space}%
  % Additional information
  \printfield{howpublished}%
  \setunit{\addperiod\space}%
  \printfield{note}%
  \setunit{\addperiod\space}%
  \printfield{addendum}%
  \usebibmacro{finentry}%
}
