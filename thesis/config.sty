  #1{#2}%
}

\begingroup
\catcode`\^^I=12
\gdef\config@insertCodeTabChar{^^I}
\endgroup

\begingroup
\catcode`\^^J=12
\catcode`\^^M=\active
\catcode`\ =\active
\catcode`\^^I=\active
\gdef\config@insertCodeWriteActiveChars{%
  \def^^M{^^J}%
  \def {\space}%
  \def^^I{\config@insertCodeTabChar}%
}
\endgroup

\long\def\config@insertCodeWriteBody#1{%
  \begingroup
  \newlinechar=`\^^J
  \catcode`\^^M=\active
  \catcode`\ =\active
  \catcode`\^^I=\active
  \config@insertCodeWriteActiveChars
  \immediate\write\config@insertCodeWrite{#1}%
  \endgroup
}

\long\def\insertCodeFinish#1#2#3{%
    \stepcounter{config@insertCode}%
    \edef\config@insertCodeFile{\jobname-insert-code-\arabic{config@insertCode}.tmp}%
    \immediate\openout\config@insertCodeWrite=\config@insertCodeFile\relax
    \config@insertCodeWriteBody{#3}%
    \immediate\closeout\config@insertCodeWrite
    \inputminted[#1]{#2}{\config@insertCodeFile}%
  \end{listing}%
}
